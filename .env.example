# Environment variables template for production deployment
# Copy this file to .env and update the values

# Database Configuration
DB_PASSWORD=your-secure-postgres-password

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters

# SMTP Settings (for email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# Business Settings
BUSINESS_NAME=Your Business Name
APP_URL=https://yourdomain.com

# Frontend Public API URL
NEXT_PUBLIC_API_URL=https://yourdomain.com/api

# M-Pesa Settings (if applicable)
MPESA_SHORTCODE=XXXXXX
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret

# Bank Transfer Details
BANK_DETAILS=Bank: Your Bank, Account: 1234567890
