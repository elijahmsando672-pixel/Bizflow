{
  "name": "bizflow",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "npm --prefix client run dev",
    "server": "node server/index.js",
    "dev:all": "concurrently \"npm --prefix client run dev\" \"npm run server\"",
    "build": "npm --prefix client run build",
    "start": "npm --prefix client run start",
    "lint": "npm --prefix client run lint"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "joi": "^17.11.0",
    "uuid": "^9.0.1",
    "nodemailer": "^6.9.8"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}